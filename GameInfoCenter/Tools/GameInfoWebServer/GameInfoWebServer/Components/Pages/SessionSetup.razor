@page "/session-setup"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Text
@using GameInfoWebServer.Models

<PageTitle>Session setup</PageTitle>

<h1>Create capture session</h1>

<p>
    Creates a server-side session and tokens for Unity ingest and browser viewing.
</p>

<button class="btn btn-primary" @onclick="CreateAsync" disabled="@_busy">Create session</button>

@if (_error is not null)
{
    <p class="text-danger">@_error</p>
}

@if (_response is not null)
{
    <div class="mt-3">
        <p><strong>SessionId:</strong> @_response.SessionId</p>
        <p><strong>Ingest token:</strong> @_response.IngestToken</p>
        <p><strong>Viewer token:</strong> @_response.ViewerToken</p>
        <p>
            <strong>Unity WebSocket:</strong>
            <code>@GetIngestWsUrl()</code>
        </p>
        <p>
            <a class="btn btn-success" href="@GetLiveUrl()">Open live view</a>
        </p>
    </div>
}

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private bool _busy;

    private string? _error;

    private CreateSessionResponse? _response;

    private async Task CreateAsync()
    {
        _busy = true;
        _error = null;
        _response = null;
        try
        {
            using var client = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
            using var content = new StringContent("{}", Encoding.UTF8, "application/json");
            using var resp = await client.PostAsync("api/sessions", content).ConfigureAwait(false);
            resp.EnsureSuccessStatusCode();
            _response = await resp.Content.ReadFromJsonAsync<CreateSessionResponse>().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private string GetLiveUrl()
    {
        if (_response is null)
        {
            return "#";
        }

        var token = Uri.EscapeDataString(_response.ViewerToken);
        return $"/live/{_response.SessionId}?token={token}";
    }

    private string GetIngestWsUrl()
    {
        if (_response is null)
        {
            return string.Empty;
        }

        var baseUri = new Uri(Navigation.BaseUri);
        var scheme = baseUri.Scheme.Equals("https", StringComparison.OrdinalIgnoreCase) ? "wss" : "ws";
        var token = Uri.EscapeDataString(_response.IngestToken);
        return $"{scheme}://{baseUri.Authority}/ws/ingest?sessionId={Uri.EscapeDataString(_response.SessionId)}&token={token}";
    }
}
